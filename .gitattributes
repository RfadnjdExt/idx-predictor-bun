# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly LF for these types
*.js        eol=lf
*.ts        eol=lf
*.svelte    eol=lf
*.json      eol=lf
*.css       eol=lf
*.html      eol=lf
*.md        eol=lf
*.toml      eol=lf
*.gitignore eol=lf

# Binary files — no conversion
*.png    binary
*.jpg    binary
*.ico    binary
*.woff2  binary
*.lockb  binary
